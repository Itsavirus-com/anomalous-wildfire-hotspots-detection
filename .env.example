# Environment Configuration Template
# ✅ This file IS safe to commit to GitHub
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env

# ─── Database ────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/wildfire_db

# ─── NASA FIRMS API ──────────────────────────────────────────
# Get a FREE key at: https://firms.modaps.eosdis.nasa.gov/api/area/
FIRMS_API_KEY=your_firms_api_key_here

# ─── H3 Spatial Indexing ─────────────────────────────────────
# Resolution 7 = ~23 km² per cell (recommended)
H3_RESOLUTION=7

# ─── ML Configuration ────────────────────────────────────────
# Fraction of data expected to be anomalous (0.0 - 0.5)
ML_CONTAMINATION=0.1
# Number of trees in Isolation Forest
ML_N_ESTIMATORS=100
# Top-K alerts to select per day
TOP_K_ALERTS=20

# ─── API Configuration ───────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─── Optional: LLM Explanations ──────────────────────────────
# Uncomment if you want natural language explanations for anomalies
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
